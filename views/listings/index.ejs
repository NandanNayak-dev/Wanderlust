<% layout("/layouts/boilerplate") %>

<div class="filters-toolbar">
  <form id="filters" action="/listings" method="get" class="filters-scroll">
    <button type="submit" class="filter filter-btn" name="category" value="Trending">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </button>

    <button type="submit" class="filter filter-btn" name="category" value="Rooms">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </button>

    <button type="submit" class="filter filter-btn" name="category" value="Iconic Cities">
      <div><i class="fa-solid fa-city"></i></div>
      <p>Iconic Cities</p>
    </button>

    <button type="submit" class="filter filter-btn" name="category" value="Castles">
      <div><i class="fa-solid fa-chess-rook"></i></div>
      <p>Castles</p>
    </button>

    <button type="submit" class="filter filter-btn" name="category" value="Amazing Pools">
      <div><i class="fa-solid fa-swimming-pool"></i></div>
      <p>Amazing Pools</p>
    </button>

    <button type="submit" class="filter filter-btn" name="category" value="Camping">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </button>

    <button type="submit" class="filter filter-btn" name="category" value="Farms">
      <div><i class="fa-solid fa-tractor"></i></div>
      <p>Farms</p>
    </button>

    <button type="submit" class="filter filter-btn" name="category" value="Arctic">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </button>
  </form>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display Total After Taxes</label>
    </div>
  </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 mt-1">
  <% for(let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link d-block h-100">
        <div class="card listing-card h-100">
          <img src="<%= listing.image.url %>" class="card-img-top listing-img" alt="listing-image">
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b> <br>
              &#8377;
              <%= listing.price != null 
                    ? listing.price.toLocaleString("en-IN") 
                    : "Price not available" %>/night
              <i class="tax-info">&nbsp;&nbsp; +18% GST</i>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>
<script>
  let taxSwitch=document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click",()=>{
    let taxInfo=document.querySelectorAll(".tax-info");
    for(let i=0;i<taxInfo.length;i++){
      if(taxSwitch.checked){
        taxInfo[i].style.display="inline";
      }else{
        taxInfo[i].style.display="none";
      }
    }
  })
</script>
