
<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-2">
<br><br>
    <h1>Create a New Listing</h1>
    <form action="/listings" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
<div class="mb-3">
<label for="title" class="form-label">Title</label>
<input type="text" name="listing[title]" placeholder="Add a catchy title" class="form-control" required>
<div class="valid-feedback">
     Title Looks good!
    </div>
</div>

<div class="mb-3">
<label for="description" class="form-label">Description</label>
<textarea name="listing[description]" class="form-control" required></textarea>
<div class="invalid-feedback">
        Please provide a description.
    </div>
</div>


<div class="mb-3">
<label for="image" class="form-label">Upload Image</label>
<input type="file" name="listing[image]" class="form-control" required>
</div>

<div class="row">
<div class="mb-3 col-md-4">
<label for="price" class="form-label">Price</label>
<input  name="listing[price]" placeholder="1200" class="form-control" required>
<div class="invalid-feedback">
        Please provide a valid price.
    </div>
</div>

<div class="mb-3 col-md-8">
<label for="country" class="form-label">Country</label>
<input type="text" name="listing[country]" placeholder="India" class="form-control" required>
<div class="invalid-feedback">
        Country name should be valid.
    </div>
</div>
</div>


<div class="mb-3">
<label for="country" class="form-label">Location</label>
<input type="text" name="listing[location]" placeholder="Jaipur,Rajasthan" class="form-control" required>
<div class="invalid-feedback">
       Location should be valid.
    </div>
</div>

<!-- Categories -->
<div class="mb-3">
    <label class="form-label d-block">Category (select one or more)</label>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catTrending" value="Trending">
        <label class="form-check-label" for="catTrending">Trending</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catRooms" value="Rooms">
        <label class="form-check-label" for="catRooms">Rooms</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catIconicCities" value="Iconic Cities">
        <label class="form-check-label" for="catIconicCities">Iconic Cities</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catCastles" value="Castles">
        <label class="form-check-label" for="catCastles">Castles</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catAmazingPools" value="Amazing Pools">
        <label class="form-check-label" for="catAmazingPools">Amazing Pools</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catCamping" value="Camping">
        <label class="form-check-label" for="catCamping">Camping</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catFarms" value="Farms">
        <label class="form-check-label" for="catFarms">Farms</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" id="catArctic" value="Arctic">
        <label class="form-check-label" for="catArctic">Arctic</label>
    </div>
</div>


<button type="submit" class="btn btn-dark add-btn mt-3 mb-3">Add</button>
    </form>
</div>
</div>

