<%if(success.length && success) { %>
<div class="alert alert-success alert-dismissible fade show col-12 col-md-10 col-lg-8 mx-auto" role="alert">
  <%= success %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<%if(error.length && error) { %>
<div class="alert alert-danger alert-dismissible fade show col-12 col-md-10 col-lg-8 mx-auto" role="alert">
  <%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>
